# ========================
# REQUIRED
# ========================

# Get from https://my.telegram.org/apps
API_ID=
API_HASH=

# Get from @BotFather
BOT_TOKEN=

# Your Telegram user ID (get from @userinfobot)
OWNER_ID=

# OPTIONAL - Private group where the bot logs activity (leave blank to disable)
LOGGER_ID=

# Pyrogram session string for the assistant account
# Generate one at @StringFatherBot
STRING_SESSION=

# ========================
# OPTIONAL - Extra assistants for multi-group load balancing
# ========================
STRING_SESSION2=
STRING_SESSION3=

# ========================
# OPTIONAL - Features
# ========================

# Automatically leave voice chat when queue is empty (True/False)
AUTO_END=False

# Auto-leave inactive groups every 30 minutes (True/False)
AUTO_LEAVE=False

# Generate custom thumbnails for now playing messages (True/False)
THUMB_GEN=True

# Max song duration in minutes (default: 300)
DURATION_LIMIT=300

# Max songs in queue (default: 30)
QUEUE_LIMIT=30

# YouTube cookies - required on cloud servers to bypass bot-detection.
# Option A: base64-encode your cookies.txt and paste here
#   Mac/Linux: base64 -i cookies.txt | tr -d '\n'
#   Windows:   certutil -encode cookies.txt tmp.b64 && type tmp.b64
COOKIES_B64=

# Option B: URL to a hosted Netscape-format cookies file
COOKIE_URL=

# Proxy for yt-dlp — REQUIRED on Railway/cloud to bypass YouTube's datacenter IP block.
# YouTube blocks datacenter IPs even with valid cookies. A residential proxy fixes this.
# Format: socks5://user:pass@host:port  OR  http://user:pass@host:port
# Free option: webshare.io has a free tier (1GB/month, enough for light use)
#   Sign up → https://proxy.webshare.io → Dashboard → Proxy → Copy "rotating endpoint"
# NordVPN/ExpressVPN users: use their SOCKS5 proxy details (included in subscription)
YTDLP_PROXY=
