# ========================
# REQUIRED
# ========================

# Get from https://my.telegram.org/apps
API_ID=
API_HASH=

# Get from @BotFather
BOT_TOKEN=

# Your Telegram user ID (get from @userinfobot)
OWNER_ID=

# OPTIONAL - Private group where the bot logs activity (leave blank to disable)
LOGGER_ID=

# Pyrogram session string for the assistant account
# Generate one at @StringFatherBot
STRING_SESSION=

# ========================
# OPTIONAL - Extra assistants for multi-group load balancing
# ========================
STRING_SESSION2=
STRING_SESSION3=

# ========================
# OPTIONAL - Features
# ========================

# Automatically leave voice chat when queue is empty (True/False)
AUTO_END=False

# Auto-leave inactive groups every 30 minutes (True/False)
AUTO_LEAVE=False

# Generate custom thumbnails for now playing messages (True/False)
THUMB_GEN=True

# Max song duration in minutes (default: 300)
DURATION_LIMIT=300

# Max songs in queue (default: 30)
QUEUE_LIMIT=30

# URL to a Netscape-format YouTube cookies file (for age-restricted content)
COOKIE_URL=
